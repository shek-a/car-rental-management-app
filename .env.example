# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real secrets.

# Random 32+ char string used by Better Auth to sign sessions.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Google OAuth 2.0 Web client credentials (Google Cloud Console → Google Auth Platform → Clients)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google email provisioned as the first ADMINISTRATOR on sign-in (not a secret, but
# deployment-specific). Without it set, no account can ever hold the administrator role.
SEED_ADMIN_EMAIL=

# MongoDB connection string. Optional — defaults to the local Docker instance
# (mongodb://localhost:27017). Production URIs often embed credentials, so they belong here,
# never in source.
MONGODB_CONNECTION_URI=
